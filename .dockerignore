# ═══════════════════════════════════════════════════════════════════════════════
#  .dockerignore — exclude non-essential files from Docker build context
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg
.pytest_cache/
.coverage
htmlcov/

# ── Node / Frontend ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
node_modules/

# ── Tests (not needed in production image) ──────────────────────────────────
tests/
test.bat
e2e_test.py

# ── Docs (not needed in production image) ────────────────────────────────────
docs/
*.md
CHANGELOG.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
SUPPORT.md
PROJECT_OVERVIEW.md
memory.md

# ── CI / Git ────────────────────────────────────────────────────────────────
.git/
.github/
.gitignore
.gitattributes

# ── Scripts (not needed in production) ──────────────────────────────────────
scripts/
Makefile
start.bat

# ── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
data/

# ── IDE / Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Environment ─────────────────────────────────────────────────────────────
.env
.env.*
