# ═══════════════════════════════════════════════════════════════════════════════
#  Union Bank Management System — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  The app will CRASH on startup if required variables are not set.
#

# ── REQUIRED: JWT signing secret (change this! At least 32 random characters) ─
#   Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long

# ── REQUIRED: Flask session signing key ───────────────────────────────────────
#   Generate one with: python -c "import secrets; print(secrets.token_hex(24))"
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── OPTIONAL: CORS allowed origins (comma-separated) ─────────────────────────
#   Default: http://localhost:5000,http://localhost:8000
#   For production, set to your actual domain(s):
#   CORS_ALLOWED_ORIGINS=https://bank.example.com
# CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8000
