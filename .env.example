# ═══════════════════════════════════════════════════════════════════════════════
#  Union Bank Management System — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  The app will CRASH on startup if required variables are not set.
#

# ── REQUIRED: JWT signing secret (generate a strong one!) ───────────────────
#   Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#   Must be at least 32 hex characters (64 chars recommended).
#   NEVER use a dictionary word, phrase, or the default below in production.
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long

# ── REQUIRED: Flask session signing key ───────────────────────────────────────
#   Generate with: python -c "import secrets; print(secrets.token_hex(24))"
#   This is used for signing Flask session cookies. Must be unique and secret.
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── OPTIONAL: CORS allowed origins (comma-separated) ─────────────────────────
#   Default: http://localhost:5000,http://localhost:8000,http://localhost:5173
#   For production, set to your actual domain(s):
#   CORS_ALLOWED_ORIGINS=https://bank.example.com,http://localhost:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8000,http://localhost:5173

# ── OPTIONAL: Frontend API URL (for Vite dev server) ─────────────────────────
#   Create Union Bank frontend/.env with:
#   VITE_API_URL=http://localhost:8000
