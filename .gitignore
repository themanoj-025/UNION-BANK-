# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environment
venv/
.venv/
env/
ENV/

# Environment & secrets (NEVER COMMIT)
.env
.env.*
!.env.example

# IDE
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Project data —───────────────────────────────────────────────────────────
# JSON data (legacy Flat‑file storage)
data/*.json
# Keep sample data trackable
!data/*.sample.json

# JSON Lines log (generated by JSON storage)
data/*.jsonl

# SQLite database files (auto‑generated, contain user data)
#      *.db      → main database
#      *.db-wal  → SQLite Write‑Ahead Log
#      *.db-shm  → SQLite Shared Memory
data/*.db
data/*.db-wal
data/*.db-shm

# Logs
data/*.log

# Backup files
data/*.bak

# Duplicate/legacy data in src/data/ (old location)
src/data/

# Backup files (auto-generated by JSON storage)
*.bak

# Logs
*.log
*.jsonl

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# OS
.DS_Store
Thumbs.db

# ── Frontend (safety nets — frontend/ has its own .gitignore) ───────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# ── AI / IDE metadata ───────────────────────────────────────────────────────
.gemini/
.cursorrules
CLAUDE.md
