# ═══════════════════════════════════════════════════════════════════════════════
#  UNION BANK  –  .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python byte-code & caches ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# ── Python build artifacts ───────────────────────────────────────────────────
*.egg-info/
*.egg
.eggs/
dist/
build/
*.egg/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Environment & secrets (NEVER COMMIT) ─────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
frontend/.env
frontend/.env.*
frontend/.env.local

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS / Windows artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.bak
nul

# ── Project data — JSON legacy storage ───────────────────────────────────────
data/*.json
!data/*.sample.json
data/*.bak

# ── Project data — Log files ─────────────────────────────────────────────────
data/*.jsonl
data/*.log
*.jsonl
*.log

# ── Project data — SQLite databases (ALL locations) ──────────────────────────
data/*.db
data/*.db-wal
data/*.db-shm
data/*.db-vacuum
src/data/*.db
src/data/*.db-wal
src/data/*.db-shm
src/**/data/*.db
src/**/data/*.db-wal
src/**/data/*.db-shm

# ── Temporary test database directories ──────────────────────────────────────
data/fresh_*/
data/seed_*/
data/test_*/
data/tmp_*/
data_test/

# ── Duplicate/legacy data directories ────────────────────────────────────────
src/data/

# ── Legacy empty stub directories ────────────────────────────────────────────
src/application/
src/domain/
src/infrastructure/
src/utils/

# ── Coverage reports ─────────────────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
.coverage/

# ── Frontend (node_modules, builds, env) ─────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ── AI / IDE metadata ───────────────────────────────────────────────────────
.gemini/
.cursorrules
CLAUDE.md
.prompt.md

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Misc generated files ─────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
